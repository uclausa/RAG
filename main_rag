# ─────────────────────────────────────────────────────────────────────────────
def setup(force_reindex: bool = False):
    """
    Pass force_reindex=True the FIRST time you run this file after adding the
    header/footer body-bbox fix, so the old image cache (cropped with the
    header/footer-INCLUSIVE content bbox) gets rebuilt using get_body_bbox().
    """
    global LAST_UPLOADED_FILE

    if force_reindex:
        for f in (CHUNKS_FILE, INDEX_FILE, IMAGE_MAP_FILE, PROCESSED_FILES, HEADER_FOOTER_MAP_FILE):
            if os.path.exists(f):
                os.remove(f)
        if os.path.isdir(IMAGES_FOLDER):
            import shutil
            shutil.rmtree(IMAGES_FOLDER)
        print("  [force_reindex] Cleared old caches — rebuilding from scratch.")

    # restore LAST_UPLOADED_FILE from disk so file disambiguation
    # (visual-section fallback in detect_file_filter) still works correctly
    # after a process restart, instead of resetting to None every time.
    LAST_UPLOADED_FILE = _load_last_uploaded()
    if LAST_UPLOADED_FILE:
        print(f"  [LAST_UPLOADED_FILE] Restored from disk → {LAST_UPLOADED_FILE}")

    print("\n── Loading chunks ──")
    if os.path.exists(CHUNKS_FILE):
        chunks = load_chunks()
        print(f"  Loaded {len(chunks)} chunks from cache")
    else:
        docs   = load_pdfs(PDF_FOLDER)
        chunks = chunk_documents(docs)
        save_chunks(chunks)

        processed = {}
        for pdf in Path(PDF_FOLDER).glob("*.pdf"):
            processed[pdf.name] = file_hash(pdf)
        save_processed(processed)

    print("\n── Loading embedding model ──")
    model = SentenceTransformer(EMBED_MODEL)

    print("\n── Loading FAISS index ──")
    if os.path.exists(INDEX_FILE):
        index = faiss.read_index(INDEX_FILE)
        print("  Loaded index from cache")
    else:
        print("  Building index …")
        index = build_index(chunks, model)

    print("\n── Building BM25 ──")
    bm25 = build_bm25(chunks)

    print("\n── Loading image map ──")
    image_map = load_image_map()

    expected_keys = {
        (c["file_name"], c["section"])
        for c in chunks
        if c["section"] in VISUAL_SECTIONS
    }
    valid_map_entries = {
        k: v for k, v in image_map.items()
        if os.path.exists(v)
    }
    covered_keys = {
        (k.split("|")[0], k.split("|")[1])
        for k in valid_map_entries
        if "|" in k
    }
    missing_keys = expected_keys - covered_keys

    if missing_keys:
        print(f"  [INFO] {len(missing_keys)} visual section(s) not in image map — extracting …")
        print(f"  Missing: {missing_keys}")
        new_images = extract_section_images(chunks)
        image_map.update(new_images)
        save_image_map(image_map)
        print(f"  Total images in map: {len(image_map)}")
    else:
        print(f"  Loaded {len(valid_map_entries)} valid image(s) from cache")

    return model, index, chunks, bm25, image_map


# ─────────────────────────────────────────────────────────────────────────────
# ASK — split into a resolve step + an answer step
#
# Previously ask() called Python's input() directly to disambiguate between
# similarly-named SOPs. That works fine in a terminal, but breaks completely
# in Streamlit: there is no stdin to read from during a script rerun, so
# input() would either hang the app or raise immediately. The fix is to
# separate "figure out which file this query targets" (pure, no I/O) from
# "actually answer" (needs a resolved file_filter). Callers — CLI or
# Streamlit — each handle the disambiguation UI in whatever way fits their
# environment, then call ask() with a concrete file_filter.
# ─────────────────────────────────────────────────────────────────────────────
def resolve_file_filter(
    query: str,
    chunks: list[dict],
    default_file: str | None = None,
) -> dict:
    """
    Step 1 — figure out which file (if any) this query targets, without
    doing any I/O or prompting.

    Returns one of:
      {"ambiguous": True,  "candidates": [file1, file2, ...]}
      {"ambiguous": False, "file_filter": file_or_None}
    """
    # ambiguous = detect_ambiguous_documents(query, chunks)
    # if ambiguous:
    #     return {"ambiguous": True, "candidates": ambiguous}

    matched_docs = detect_ambiguous_documents(query, chunks)

    if matched_docs:
        # Search only these PDFs
        filtered_chunks = [
            c for c in chunks
            if c["file_name"] in matched_docs
        ]
    else:
        # Search every PDF
        filtered_chunks = chunks

    file_filter = detect_file_filter(query, chunks, default_file=default_file)
    return {"ambiguous": False, "file_filter": file_filter}


def ask(query, model, index, chunks, bm25, image_map, file_filter):
    """
    Step 2 — actually answer, given an already-resolved file_filter (may be
    None, meaning "search everything"). Callers must call
    resolve_file_filter() first and handle the ambiguous case (asking the
    user to pick) before calling this.
    """
    print(f"[DEBUG] file_filter = {file_filter}")

    # ------------------------------------------------------------
    # Decide which retrieval pipeline to use
    # ------------------------------------------------------------

    if is_general_question(query, chunks):

        ranked_documents = retrieve_general(
            query=query,
            model=model,
            index=index,
            chunks=chunks,
            bm25=bm25,
        )

        ranked_documents = balance_documents(
            ranked_documents
        )

        retrieved = flatten_ranked_documents(
            ranked_documents
        )

        prompt = build_general_prompt(
            query,
            ranked_documents,
        )

    else:

        retrieved = retrieve(
            query=query,
            model=model,
            index=index,
            chunks=chunks,
            bm25=bm25,
            file_filter=file_filter,
        )

        prompt = build_prompt(
            query,
            retrieved,
        )

    if not retrieved:
        # Nothing cleared the relevance bar. Previously retrieve() would
        # still force through its top 3 (irrelevant) chunks here, and the
        # LLM would be asked to answer from them anyway -- the single
        # biggest source of confident-sounding fabrication. Skipping the
        # LLM call entirely when there's genuinely nothing relevant is far
        # safer than handing it thin context and hoping the prompt rules
        # stop it from filling the gap with general knowledge.
        scope = f" in '{file_filter}'" if file_filter else ""
        answer = (
            f"I couldn't find anything in the SOP documents{scope} "
            f"that answers this question."
        )
        return answer, [], file_filter, []

    answer = generate(prompt)

    images = get_chunk_images(
        retrieved,
        image_map,
        query=query,
        file_filter=file_filter,
        chunks=chunks,
    )

    return answer, retrieved, file_filter, images


