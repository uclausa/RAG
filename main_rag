# BM25
# ─────────────────────────────────────────────────────────────────────────────
def build_bm25(chunks):
    corpus = [
        (c["section"] + " " + c["file_name"] + " " + c["text"]).lower().split()
        for c in chunks
    ]
    return BM25Okapi(corpus)


# ─────────────────────────────────────────────────────────────────────────────
# FILE FILTER
# ─────────────────────────────────────────────────────────────────────────────
def _normalise(s: str) -> str:
    return re.sub(r"[\s\-_]+", " ", Path(s).stem.lower()).strip()

def _meaningful_tokens(s: str) -> list[str]:
    return [t for t in s.split() if len(t) > 2]

# Generic filename words that show up across many SOP files and shouldn't,
# on their own, count as evidence that a SPECIFIC file was named. Matching
# only on words like these is exactly how an unrelated file could win the
# old raw-count check (best_score >= 2): e.g. two totally different SOPs
# both containing "sop" and "final" would tie/overlap on those words alone.
GENERIC_FILE_WORDS = {
    "sop", "pdf", "doc", "docx", "document", "file", "files",
    "final", "draft", "copy", "rev", "revision", "revised",
    "version", "ver", "v", "update", "updated", "new", "old",
    "latest", "master", "template",
}

def _distinctive_tokens(tokens: list[str]) -> list[str]:
    """
    Strip generic filler words and pure numbers (e.g. 'v2' -> '2' already
    dropped by GENERIC_FILE_WORDS covering 'v'; standalone digit tokens
    like version numbers are dropped too) so what's left is the part of
    the filename that actually identifies WHICH document this is.
    Falls back to the full token list if a filename is made up entirely
    of generic words, so we never end up with zero tokens to match on.
    """
    distinctive = [
        t for t in tokens
        if t not in GENERIC_FILE_WORDS and not t.isdigit()
    ]
    return distinctive if distinctive else tokens


def _file_match_ratio(file_name: str, q_norm: str) -> tuple[float, int]:
    """
    Returns (coverage_ratio, num_distinctive_tokens) describing how much of
    THIS file's distinctive name-tokens are actually present in the query,
    using word-boundary matching (so 'sop' doesn't match inside a longer
    word like 'sophisticated', and short tokens don't false-hit on
    substrings of unrelated words).
    """
    tokens      = _meaningful_tokens(_normalise(file_name))
    distinctive = _distinctive_tokens(tokens)
    matched = [
        t for t in distinctive
        if re.search(rf"\b{re.escape(t)}\b", q_norm)
    ]
    ratio = len(matched) / len(distinctive) if distinctive else 0.0
    return ratio, len(distinctive)


