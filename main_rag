# FAISS INDEX
# ─────────────────────────────────────────────────────────────────────────────
def _chunk_to_text(c):
    return (
        f"File: {c['file_name']}\n"
        f"Section: {c['section']}\n\n"
        f"{c['text']}"
    )

def build_index(chunks, model):
    texts = [_chunk_to_text(c) for c in chunks]
    emb   = model.encode(texts, normalize_embeddings=True, batch_size=32, show_progress_bar=True)
    index = faiss.IndexFlatIP(emb.shape[1])
    index.add(np.array(emb, dtype="float32"))
    faiss.write_index(index, INDEX_FILE)
    return index

def build_sub_index(model, chunks):
    texts = [_chunk_to_text(c) for c in chunks]
    emb   = model.encode(texts, normalize_embeddings=True, show_progress_bar=False)
    index = faiss.IndexFlatIP(emb.shape[1])
    index.add(np.array(emb, dtype="float32"))
    return index


