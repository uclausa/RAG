def is_general_question(
    query: str,
    chunks: list[dict],
) -> bool:
    """
    Decide whether the query is asking about
    a GENERAL CONCEPT or about one specific SOP.

    Examples
    --------

    What is schematic design?
        -> True

    Responsibilities of Project Manager
        -> True

    What is SIPOC?
        -> True

    Show RACI matrix
        -> False (visual section)

    Summarize this SOP
        -> False

    Explain Building Permit SOP
        -> False
    """

    q = query.lower().strip()

    # -------------------------------------------------------
    # If the user clearly mentioned a filename,
    # this is NOT a generalized search.
    # -------------------------------------------------------

    if detect_file_filter(query, chunks) is not None:
        return False

    # -------------------------------------------------------
    # Summary requests are document-specific.
    # -------------------------------------------------------

    if _is_summary_query(query):
        return False

    # -------------------------------------------------------
    # Visual sections should use the existing pipeline.
    # -------------------------------------------------------

    if _detect_visual_section(query):
        return False

    # -------------------------------------------------------
    # Section names should use existing retrieval.
    # -------------------------------------------------------

    for sec in SECTION_NAMES_LOWER:

        if sec in q:

            return False

    # -------------------------------------------------------
    # General question patterns
    # -------------------------------------------------------

    for pattern in GENERAL_PATTERNS:

        if pattern in q:

            return True

    return False

