# CLI
# ─────────────────────────────────────────────────────────────────────────────
if __name__ == "__main__":
    # NOTE: set force_reindex=True for the first run after adding the
    # get_body_bbox() header/footer fix, so old (still-cropped-with-header/
    # footer) images get rebuilt. Switch back to False afterwards for
    # normal incremental runs.
    model, index, chunks, bm25, image_map = setup(force_reindex=True)

    print("\n" + "═" * 60)
    print("  RAG SYSTEM READY — type 'exit' to quit")
    print("═" * 60 + "\n")

    while True:
        q = input("Question: ").strip()
        if not q:
            continue
        if q.lower() in {"exit", "quit"}:
            break

        resolution = resolve_file_filter(q, chunks, default_file=LAST_UPLOADED_FILE)

        if resolution["ambiguous"]:
            candidates = resolution["candidates"]

            print("\nI found multiple SOPs matching your query:\n")
            for i, f in enumerate(candidates, 1):
                print(f"{i}. {Path(f).stem}")

            file_filter = None
            while file_filter is None:
                choice = input(
                    "\nSelect a document (number or part of the name): "
                ).strip()

                if choice.isdigit():
                    idx = int(choice) - 1
                    if 0 <= idx < len(candidates):
                        file_filter = candidates[idx]
                        break

                found = next(
                    (f for f in candidates if choice.lower() in f.lower()),
                    None,
                )
                if found:
                    file_filter = found
                    break

                print("Invalid selection. Please try again.")
        else:
            file_filter = resolution["file_filter"]

        answer, sources, file_filter, images = ask(
            q, model, index, chunks, bm25, image_map, file_filter
        )

        print("\n" + "─" * 60)
        if file_filter:
            print(f"  [File filter applied: {file_filter}]")
        print(f"\nANSWER:\n{answer}\n")

        if images:
            print("VISUAL REFERENCES:")
            for img in images:
                pages_str = (
                    f"Pages {img['pages'][0]}–{img['pages'][-1]}"
                    if len(img["pages"]) > 1
                    else f"Page {img['pages'][0]}"
                )
                print(f"  [{img['file_name']} | {img['section']} | {pages_str}]")
                print(f"  → {img['image_path']}")
        else:
            print("VISUAL REFERENCES: (none)")

        print("\nSOURCES:")
        for i, s in enumerate(sources[:5], 1):
            print(f"  {i}. {s['file_name']} | {s['section']} | Page {s['page']} "
                  f"(score={s['score']:.3f})")
        print("─" * 60 + "\n")
