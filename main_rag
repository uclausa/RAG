# PDF LOADING
# ─────────────────────────────────────────────────────────────────────────────
def load_pdfs(folder: str) -> list[dict]:
    """
    Loads and text-extracts every PDF in `folder`.

    Wrapped per-file in try/except: previously an exception analyzing ANY
    single PDF (e.g. the UnboundLocalError-style crashes seen while
    debugging PDFLayoutCleaner) would abort the whole loop, silently
    dropping every PDF that came after the broken one — which is exactly
    the kind of thing that makes RACI/SIPOC/flowchart images "just not
    show up" for some PDFs with no clear reason. Now a broken PDF is
    logged with a full traceback and skipped, and every other PDF still
    gets processed.
    """
    docs = []
    layout_cache_json = load_layout_cache_json()

    for file in sorted(Path(folder).glob("*.pdf")):
        try:
            pdf     = fitz.open(str(file))
            cleaner = get_layout_cleaner(pdf, file.name, layout_cache_json)
            pages   = []
            for i in range(len(pdf)):
                # get_clean_text() drops repeated header/footer boilerplate
                # (title, doc number, version, page numbers, dates,
                # confidentiality text, etc.) detected from the page's OWN
                # content area — not a fixed-coordinate crop — so it holds up
                # even on pages where content is shifted within the page.
                text = cleaner.get_clean_text(pdf[i]).strip()
                # Always track the page, even if it has no extractable
                # text. Table/flowchart continuation pages are often mostly a
                # graphic with little or no text — dropping them here means
                # they can never appear in a visual section's page range, which
                # was silently truncating multi-page RACI/SIPOC/flowchart crops.
                pages.append({"page": i + 1, "text": text})
            pdf.close()
            if pages:
                docs.append({"file_name": file.name, "pages": pages})
        except Exception as e:
            print(f"\n  [ERROR] Failed to load/analyze '{file.name}': {e}")
            traceback.print_exc()
            print(f"  [SKIP] Continuing with remaining PDFs...\n")
            continue

    save_layout_cache_json(layout_cache_json)
    print(f"  Loaded {len(docs)} PDF(s) from '{folder}'")
    return docs


# ─────────────────────────────────────────────────────────────────────────────
# HEADER / FOOTER CLEANING (TEXT CHUNKS)
# ─────────────────────────────────────────────────────────────────────────────
def clean_chunk_text(text: str) -> str:
    lines   = text.splitlines()
    cleaned = [l for l in lines if not INLINE_HEADER_PATTERN.match(l.strip())]
    return " ".join(" ".join(cleaned).split()).strip()


# ─────────────────────────────────────────────────────────────────────────────
# CHUNKING
# ─────────────────────────────────────────────────────────────────────────────
def chunk_documents(docs):
    chunks   = []
    chunk_id = 0

    MAX_SECTION_WORDS = 700
    CHUNK_OVERLAP     = 100

    for doc in docs:
        file_name        = doc["file_name"]
        all_page_numbers = [p["page"] for p in doc["pages"]]

        all_lines = []
        for p in doc["pages"]:
            for line in p["text"].split("\n"):
                all_lines.append((p["page"], line))

        current_section = "Cover Page"
        section_lines   = []
        section_start   = 1
        last_page_seen  = 1

        def flush(buf, section, start_page, end_page, next_section_page=None):
            nonlocal chunk_id

            raw  = " ".join(" ".join(buf).split()).strip()
            text = clean_chunk_text(raw)
            words = text.split()

            is_visual = section in VISUAL_SECTIONS

            if len(words) < MIN_CHUNK_WORDS and not is_visual:
                return

            # Visual sections (RACI / SIPOC / flowchart) get their
            # page range from the SECTION BOUNDARIES (start_page →
            # next_section_page - 1, or the doc's last page if this is the
            # final section) instead of from `end_page` (= last_page_seen).
            # `last_page_seen` only advances on lines with actual text, so a
            # near-blank continuation page (common for table/flowchart pages)
            # never bumps it — which was silently truncating the page range
            # and breaking multi-page crops / dropping sections whose only
            # content is on a text-sparse page.
            if is_visual:
                if next_section_page is not None:
                    range_end = next_section_page   # inclusive — the
                    # table/flowchart may genuinely continue onto the same
                    # page the next section's heading starts on. We keep
                    # that page and let _find_next_section_top() (in the
                    # crop functions) clip it above the next heading,
                    # instead of discarding the whole page and losing
                    # content that was legitimately part of this section.
                else:
                    range_end = max(all_page_numbers, default=start_page)
                range_end = max(range_end, start_page)
                all_pages = list(range(start_page, range_end + 1))
            else:
                all_pages = [p for p in all_page_numbers if start_page <= p <= end_page]
                if not all_pages:
                    all_pages = [start_page]

                if (
                    next_section_page is not None
                    and all_pages
                    and all_pages[-1] == next_section_page
                ):
                    all_pages = all_pages[:-1]

                if not all_pages:
                    all_pages = [start_page]

            if is_visual and len(words) < MIN_CHUNK_WORDS:
                placeholder_text = text if text else f"{section} section (visual content)."
                chunks.append({
                    "chunk_id":   chunk_id,
                    "text":       placeholder_text,
                    "file_name":  file_name,
                    "page":       start_page,
                    "all_pages":  all_pages,
                    "page_end":   all_pages[-1],
                    "section":    section,
                    "word_count": len(words),
                })
                chunk_id += 1
                return

            if len(words) <= MAX_SECTION_WORDS:
                chunks.append({
                    "chunk_id":   chunk_id,
                    "text":       text,
                    "file_name":  file_name,
                    "page":       start_page,
                    "all_pages":  all_pages,
                    "page_end":   all_pages[-1],
                    "section":    section,
                    "word_count": len(words),
                })
                chunk_id += 1
                return

            step = MAX_SECTION_WORDS - CHUNK_OVERLAP
            for start in range(0, len(words), step):
                chunk_words = words[start:start + MAX_SECTION_WORDS]
                if len(chunk_words) < MIN_CHUNK_WORDS:
                    break
                chunks.append({
                    "chunk_id":   chunk_id,
                    "text":       " ".join(chunk_words),
                    "file_name":  file_name,
                    "page":       start_page,
                    "all_pages":  all_pages,
                    "page_end":   all_pages[-1],
                    "section":    section,
                    "word_count": len(chunk_words),
                })
                chunk_id += 1

        for page_num, line in all_lines:
            line = line.strip()
            if not line:
                continue
            if page_num > last_page_seen:
                last_page_seen = page_num

            match = SECTION_PATTERN.match(line)
            if match:
                flush(
                    section_lines, current_section,
                    section_start, last_page_seen,
                    next_section_page=page_num,
                )
                current_section = match.group(2)
                section_lines   = []
                section_start   = page_num
                last_page_seen  = page_num
            else:
                section_lines.append(line)

        flush(section_lines, current_section, section_start, last_page_seen)

    print(f"Created {len(chunks)} chunk(s)")
    if chunks:
        print("Largest chunk:", max(c["word_count"] for c in chunks))
    return chunks


