    matched = []

    for filename in set(c["file_name"] for c in chunks):

        stem = Path(filename).stem.lower()

        if stem in query_lower:
            matched.append(filename)

    return matched


def detect_file_filter(
    query: str,
    chunks: list[dict],
    default_file: str | None = None,
) -> str | None:
    q_norm = _normalise(query)
    files  = list({c["file_name"] for c in chunks})

    # ── Coverage-ratio name match ───────────────────────────────────────
    ratios = {f: _file_match_ratio(f, q_norm) for f in files}
    ranked = sorted(ratios.items(), key=lambda kv: (kv[1][0], kv[1][1]), reverse=True)

    if ranked:
        best_file, (best_ratio, best_n) = ranked[0]
        second_ratio = ranked[1][1][0] if len(ranked) > 1 else 0.0
        margin = best_ratio - second_ratio

        print(f"[file_filter] Coverage ratios: "
              f"{[(f, round(r, 2)) for f, (r, _) in ranked[:5]]}")

        if best_ratio >= 0.6 and margin >= 0.25:
            print(f"[file_filter] Confident name match "
                  f"(ratio={best_ratio:.2f}, margin={margin:.2f}) → {best_file}")
            return best_file

    def _bow(text: str) -> dict:
        toks = text.split()
        bag: dict[str, int] = {}
        for t in toks:
            bag[t] = bag.get(t, 0) + 1
        for i in range(len(toks) - 1):
            bg = toks[i] + "_" + toks[i + 1]
            bag[bg] = bag.get(bg, 0) + 1
        return bag

    q_bow = _bow(q_norm)

    def _cosine(a: dict, b: dict) -> float:
        shared = sum(a.get(k, 0) * v for k, v in b.items())
        norm_a = sum(v * v for v in a.values()) ** 0.5
        norm_b = sum(v * v for v in b.values()) ** 0.5
        return shared / (norm_a * norm_b + 1e-9)

    sim_scores  = {f: _cosine(q_bow, _bow(_normalise(f))) for f in files}
    top_file    = max(sim_scores, key=sim_scores.get)
    top_sim     = sim_scores[top_file]
    sorted_sims = sorted(sim_scores.values(), reverse=True)
    margin      = (sorted_sims[0] - sorted_sims[1]) if len(sorted_sims) > 1 else sorted_sims[0]

    if top_sim > 0.15 and margin > 0.05:
        print(f"[file_filter] Cosine sim ({top_sim:.3f}, margin {margin:.3f}) → {top_file}")
        return top_file

    # ── Visual section fallback ─────────────────────────────────────────────
    visual_section = _detect_visual_section(query)
    if visual_section:
        files_with_section = list({
            c["file_name"] for c in chunks
            if c["section"] == visual_section
        })
        if default_file and default_file in files_with_section:
            print(f"[file_filter] Visual section + last uploaded → {default_file}")
            return default_file
        if len(files_with_section) == 1:
            print(f"[file_filter] Single-file visual section → {files_with_section[0]}")
            return files_with_section[0]
        if len(files_with_section) > 1:
            candidate_sims = {f: sim_scores.get(f, 0.0) for f in files_with_section}
            best_candidate = max(candidate_sims, key=candidate_sims.get)
            print(f"[file_filter] Ambiguous visual section across "
                  f"{len(files_with_section)} files — best guess → {best_candidate}")
            return best_candidate

    if default_file and default_file in files:
        print(f"[file_filter] No confident match — defaulting to last uploaded: {default_file}")
        return default_file

    print("[file_filter] No confident match → searching all files")
    return None


# ─────────────────────────────────────────────────────────────────────────────
# IMAGE HELPERS
# ─────────────────────────────────────────────────────────────────────────────
def _page_content_rect(page: fitz.Page, cleaner: "PDFLayoutCleaner") -> fitz.Rect:
    """
    This page's real BODY content area -- header/footer strips excluded --
    detected by PDFLayoutCleaner from the actual text/drawings/images on
    the page, not a fixed offset.

    IMPORTANT: this calls get_body_bbox(), not get_content_bbox().
    get_content_bbox() is a bounding box around EVERYTHING on the page,
    including headers and footers -- they're real drawn content, so they
    were never excluded from it. That mismatch (comment said "excluded",
    code returned "included") is exactly why headers/footers were still
    showing up in stitched table/flowchart images: the crop's top/bottom
    bounds were being computed from a box that already extended from the
    header down to the footer. get_body_bbox() additionally trims past
    whatever boilerplate PDFLayoutCleaner detected in the header/footer
    zones, so the crop actually starts/ends at real body content.
    """
    return cleaner.get_body_bbox(page)


# ── per-PDF content-area + header/footer auto-detection ────────────────────
# (delegated to pdf_layout_cleaner.PDFLayoutCleaner — see that module for the
# two-pass algorithm: content bbox per page, then boilerplate signatures
# that recur across a majority of pages within each page's own header/
# footer zone.)

def load_layout_cache_json() -> dict:
    if os.path.exists(HEADER_FOOTER_MAP_FILE):
        with open(HEADER_FOOTER_MAP_FILE, encoding="utf-8") as f:
            return json.load(f)
    return {}


def save_layout_cache_json(cache_json: dict) -> None:
    with open(HEADER_FOOTER_MAP_FILE, "w", encoding="utf-8") as f:
        json.dump(cache_json, f, indent=2)


def get_layout_cleaner(
    pdf: fitz.Document,
    file_name: str,
    cache_json: dict | None = None,
) -> "PDFLayoutCleaner":
    """
    Cached wrapper around PDFLayoutCleaner — analyzes a PDF once per file
    and reuses the result. Checks the in-memory cache first, then the
    on-disk JSON cache (cache_json, typically loaded once per run via
    load_layout_cache_json()), and only re-runs the analysis if neither
    has it. When cache_json is supplied, freshly-analyzed results are
    written back into it so the caller can persist them.
    """
    if file_name in _LAYOUT_CLEANER_CACHE:
        return _LAYOUT_CLEANER_CACHE[file_name]

    kwargs = dict(
        header_zone_frac=LAYOUT_HEADER_ZONE_FRAC,
        footer_zone_frac=LAYOUT_FOOTER_ZONE_FRAC,
        min_repeat_frac=LAYOUT_MIN_REPEAT_FRAC,
    )

    if cache_json is not None and file_name in cache_json:
        cleaner = PDFLayoutCleaner.from_cache_dict(pdf, cache_json[file_name], **kwargs)
    else:
        cleaner = PDFLayoutCleaner(pdf, **kwargs)
        cleaner.analyze()
        if cache_json is not None:
            cache_json[file_name] = cleaner.to_cache_dict()

    _LAYOUT_CLEANER_CACHE[file_name] = cleaner
    return cleaner


def _find_heading_bottom(page: fitz.Page, section_name: str, content: fitz.Rect) -> float:
    GAP = 8  # breathing room below the heading line

    hits = page.search_for(section_name)
    if hits:
        return max(content.y0, max(h.y1 for h in hits) + GAP)

    needle   = section_name.lower().strip()
    best_y1  = None
    best_len = None

    for block in page.get_text("blocks"):
        if len(block) < 5 or block[6] != 0:   # skip image blocks
            continue
        block_text = block[4].strip().lower()
        if needle in block_text:
            by1 = block[3]
            blen = len(block_text)
            if best_y1 is None or by1 < best_y1 or (by1 == best_y1 and blen < best_len):
                best_y1  = by1
                best_len = blen

    if best_y1 is not None:
        return max(content.y0, best_y1 + GAP)

    return content.y0   # safe fallback


# ── find where the NEXT section heading starts on this page ────────────────
def _find_next_section_top(
    page: fitz.Page,
    current_section: str,
    after_y: float,
) -> float | None:
    best_top = None
    current_norm = current_section.strip().lower()

    for block in page.get_text("blocks"):
        if len(block) < 5 or block[6] != 0:   # skip image blocks
            continue
        bx0, by0, bx1, by1, btext = block[0], block[1], block[2], block[3], block[4]
        if by0 <= after_y + 1:
            continue
        for line in btext.splitlines():
            line = line.strip()
            if not line:
                continue
            m = SECTION_PATTERN.match(line)
            if m and m.group(2).strip().lower() != current_norm:
                if best_top is None or by0 < best_top:
                    best_top = by0
                break

    return best_top


def _rasterise_rect(page: fitz.Page, rect: fitz.Rect, dpi: int = IMAGE_DPI) -> Image.Image:
    mat = fitz.Matrix(dpi / 72, dpi / 72)
    pix = page.get_pixmap(matrix=mat, clip=rect, colorspace=fitz.csRGB)
    return Image.frombytes("RGB", [pix.width, pix.height], pix.samples)


def _rasterise_fallback(page: fitz.Page, dpi: int = IMAGE_DPI) -> Image.Image:
    """
    Guaranteed fallback for rendering a page region.

    Used whenever a computed content-area crop is too small/degenerate to
    trust (content.height < MIN_CONTENT_HEIGHT). Previously those pages
    were simply skipped (`continue`), which meant that if a table or
    flowchart happened to be drawn with faint vector lines or a
    low-contrast image that PDFLayoutCleaner's bbox detection missed, the
    page contributed NOTHING to the stitched image — and if that happened
    on every page in a section's range, no image got saved at all. This
    guarantees SOME image is produced (the whole page, uncropped) rather
    than silently dropping the section.
    """
    return _rasterise_rect(page, page.rect, dpi)


def _stitch_vertical(page_images: list[Image.Image]) -> Image.Image:
    if len(page_images) == 1:
        return page_images[0]
    total_w = max(img.width  for img in page_images)
    total_h = sum(img.height for img in page_images)
    canvas  = Image.new("RGB", (total_w, total_h), color=(255, 255, 255))
    y = 0
    for img in page_images:
        x = (total_w - img.width) // 2
        canvas.paste(img, (x, y))
        y += img.height
    return canvas


# ─────────────────────────────────────────────────────────────────────────────
# TABLE CROP  (RACI / SIPOC)
# ─────────────────────────────────────────────────────────────────────────────
def _rasterise_table_crops(
    pdf:          fitz.Document,
    all_pages:    list[int],
    section_name: str,
    cleaner:      "PDFLayoutCleaner",
    dpi:          int = IMAGE_DPI,
) -> Image.Image | None:
    crops: list[Image.Image] = []
    last_idx = len(all_pages) - 1

    for page_idx, page_num in enumerate(all_pages):
        pdf_page_index = page_num - 1
        if pdf_page_index >= len(pdf):
            continue

        page    = pdf[pdf_page_index]
        content = _page_content_rect(page, cleaner)

        if content.height < MIN_CONTENT_HEIGHT:
            # Previously: print [SKIP] and `continue`, dropping this page
            # entirely. Now: fall back to rasterising the WHOLE page so the
            # table/flowchart still shows up (uncropped) instead of the
            # section silently losing this page's content — and, in the
            # worst case where every page in the range hits this branch,
            # instead of no image being produced at all.
            print(f"    [FALLBACK] Page {page_num}: content rect too small "
                  f"({content.height:.0f}pt) — using full page instead of skipping")
            crops.append(_rasterise_fallback(page, dpi))
            continue

        if page_idx == 0:
            top = _find_heading_bottom(page, section_name, content)
        else:
            top = max(page.rect.y0, content.y0 - OVERLAP_PX)

        bottom = min(page.rect.y1, content.y1 + BOTTOM_BLEED_PX)

        # Only scan for the next section's heading on the LAST page
        # of this range. Earlier pages are guaranteed by the chunk-level
        # page-range calculation to belong fully to THIS section — scanning
        # them was producing false positives from ordinary words (e.g.
        # "Responsibilities", "Scope") that show up as swimlane/column
        # labels inside the table or flowchart itself, wrongly skipping
        # legitimate continuation pages.
        is_last_page = (page_idx == last_idx)
        if is_last_page:
            next_top = _find_next_section_top(page, section_name, top)
            if next_top is not None and next_top > top:
                bottom = min(bottom, next_top - NEXT_HEADING_GAP_PX)
            if next_top is not None and page_idx > 0 and (next_top - top) < MIN_CONTENT_HEIGHT:
                print(f"    [SKIP] Page {page_num}: no real '{section_name}' content "
                      f"before next heading — belongs to next section")
                continue

        crop = fitz.Rect(content.x0, top, content.x1, bottom)

        if crop.is_empty or crop.height < 10:
            print(f"    [WARN] Degenerate crop on page {page_num} for "
                  f"'{section_name}' — using full content area")
            crop = fitz.Rect(content.x0, content.y0, content.x1, content.y1)

        if crop.is_empty or crop.height < 10:
            # Even the "full content area" fallback above came back
            # degenerate (content itself was near-empty) -- last resort is
            # the whole physical page, so we still produce SOMETHING.
            print(f"    [FALLBACK] Page {page_num}: content area also "
                  f"degenerate — using full page")
            crops.append(_rasterise_fallback(page, dpi))
            continue

        crops.append(_rasterise_rect(page, crop, dpi))

    return _stitch_vertical(crops) if crops else None


# ─────────────────────────────────────────────────────────────────────────────
# FLOWCHART CROP
# ─────────────────────────────────────────────────────────────────────────────
def _rasterise_flowchart(
    page:          fitz.Page,
    section_name:  str,
    cleaner:       "PDFLayoutCleaner",
    dpi:           int = IMAGE_DPI,
    is_first_page: bool = True,
    is_last_page:  bool = True,           # only the last page of the range can be shared with the next section
) -> Image.Image:
    content = _page_content_rect(page, cleaner)

    if content.height < MIN_CONTENT_HEIGHT:
        # Same fallback reasoning as _rasterise_table_crops: a too-small
        # detected content rect used to mean this page contributed nothing.
        # Returning None here (instead of a guaranteed image) is exactly
        # how a flowchart could end up with NO saved image at all if this
        # happened on its only page. Render the whole page instead.
        print(f"    [FALLBACK] Flowchart page: content rect too small "
              f"({content.height:.0f}pt) — using full page instead of skipping")
        return _rasterise_fallback(page, dpi)

    if is_first_page:
        top = _find_heading_bottom(page, section_name, content)
    else:
        top = max(page.rect.y0, content.y0 - OVERLAP_PX)

    bottom = min(page.rect.y1, content.y1 + BOTTOM_BLEED_PX)

    # Only scan for the next section's heading on the LAST page of
    # the range — earlier continuation pages are guaranteed to belong fully
    # to this section, and scanning them risks false positives from
    # ordinary words used as labels inside the flowchart itself (e.g. a
    # swimlane titled "Responsibilities" or "Scope").
    if is_last_page:
        next_top = _find_next_section_top(page, section_name, top)
        if next_top is not None and next_top > top:
            bottom = min(bottom, next_top - NEXT_HEADING_GAP_PX)
        if next_top is not None and not is_first_page and (next_top - top) < MIN_CONTENT_HEIGHT:
            return None

    crop = fitz.Rect(content.x0, top, content.x1, bottom)

    if crop.is_empty or crop.height < 10:
        crop = fitz.Rect(content.x0, content.y0, content.x1, content.y1)

    if crop.is_empty or crop.height < 10:
        # Last-resort fallback: whole page, so a degenerate content area
        # doesn't result in a missing flowchart image.
        print(f"    [FALLBACK] Flowchart page: content area also "
              f"degenerate — using full page")
        return _rasterise_fallback(page, dpi)

    return _rasterise_rect(page, crop, dpi)


# ─────────────────────────────────────────────────────────────────────────────
# IMAGE EXTRACTION
# ─────────────────────────────────────────────────────────────────────────────
def extract_section_images(chunks: list[dict]) -> dict[str, str]:
    """
    Renders and saves one stitched image per (file, visual section).

    Wrapped per (file, section) in try/except: previously an exception
    while opening/analyzing/cropping ANY single file's section (the
    UnboundLocalError-style crash seen while debugging) would propagate
    all the way up and abort the entire extraction run — silently
    skipping every remaining file/section that hadn't been processed
    yet. Now a failure is logged with a full traceback for just that
    (file, section) pair, and every other pair still gets processed and
    saved normally.
    """
    os.makedirs(IMAGES_FOLDER, exist_ok=True)
    image_map: dict[str, str] = {}

    # per-PDF layout analysis cache (content bbox + boilerplate signatures),
    # persisted across runs
    layout_cache_json = load_layout_cache_json()

    section_pages: dict[tuple, list[int]] = {}
    for chunk in chunks:
        section = chunk["section"]
        if section not in VISUAL_SECTIONS:
            continue
        key = (chunk["file_name"], section)
        all_pages = chunk.get("all_pages") or [chunk["page"]]
        existing  = section_pages.get(key, [])
        merged    = sorted(set(existing + all_pages))
        section_pages[key] = merged

    for (file_name, section), all_pages in section_pages.items():
        map_key = f"{file_name}|{section}|pages{all_pages[0]}-{all_pages[-1]}"

        pdf_path = os.path.join(PDF_FOLDER, file_name)
        if not os.path.exists(pdf_path):
            print(f"  [WARN] PDF not found: {pdf_path}")
            continue

        print(f"  [DEBUG] Extracting '{section}' from {file_name}, pages={all_pages}")

        stitched = None
        try:
            pdf = fitz.open(pdf_path)

            # get (and cache) this PDF's real content-area + boilerplate analysis
            cleaner = get_layout_cleaner(pdf, file_name, layout_cache_json)
            print(f"    [DEBUG] layout cleaner ready for {file_name}: "
                  f"{len(cleaner._boilerplate_signatures)} boilerplate signature(s) detected")

            if section in TABLE_SECTIONS:
                stitched = _rasterise_table_crops(
                    pdf, all_pages, section, cleaner,
                )
            else:
                strips = []
                for i, pg in enumerate(all_pages):
                    pi = pg - 1
                    if pi < len(pdf):
                        strip = _rasterise_flowchart(
                            pdf[pi],
                            section,
                            cleaner,
                            dpi=IMAGE_DPI,
                            is_first_page=(i == 0),
                            is_last_page=(i == len(all_pages) - 1),
                        )
                        if strip is not None:   # skip pages that turned out to belong to the next section
                            strips.append(strip)
                stitched = _stitch_vertical(strips) if strips else None

            pdf.close()
        except Exception as e:
            print(f"  [ERROR] Crop failed for '{section}' in {file_name}: {e}")
            traceback.print_exc()
            print(f"  [SKIP] Moving to next section/file...\n")
            continue

        if stitched is None:
            print(f"  [WARN] No image produced for '{section}' in {file_name}")
            continue

        safe_name = re.sub(r"[^\w\-.]", "_", map_key) + ".jpg"
        out_path  = os.path.join(IMAGES_FOLDER, safe_name)
        stitched.save(out_path, "JPEG", quality=90)
        image_map[map_key] = out_path
        print(f"  Saved image for '{section}' ({len(all_pages)} page(s)): {out_path}")

    # persist the layout analysis cache so future runs skip re-detection
    save_layout_cache_json(layout_cache_json)

    return image_map


# ─────────────────────────────────────────────────────────────────────────────
# IMAGE MAP I/O
# ─────────────────────────────────────────────────────────────────────────────
def save_image_map(image_map):
    with open(IMAGE_MAP_FILE, "w", encoding="utf-8") as f:
        json.dump(image_map, f, indent=2)

def load_image_map():
    if os.path.exists(IMAGE_MAP_FILE):
        with open(IMAGE_MAP_FILE, encoding="utf-8") as f:
            return json.load(f)
    return {}


# ─────────────────────────────────────────────────────────────────────────────
# IMAGE LOOKUP
# ─────────────────────────────────────────────────────────────────────────────
def get_chunk_images(
    retrieved_chunks: list[dict],
    image_map:        dict[str, str],
    query:            str = "",
    file_filter:      str | None = None,
    chunks:           list[dict] | None = None,
) -> list[dict]:
    images = []
    seen   = set()

    def _file_matches(map_file: str, filter_file: str) -> bool:
        return map_file.lower() == filter_file.lower()

    allowed_files = None
    if not file_filter:
        allowed_files = {c["file_name"] for c in retrieved_chunks}

    target_section = _detect_visual_section(query) if query else None

    # When there's no explicit file_filter and the query targets a
    # specific visual section (RACI / SIPOC / flowchart), don't leave
    # `allowed_files` as the union of every file that happened to appear in
    # `retrieved_chunks` — that union is exactly how images from an
    # unrelated document were slipping into the answer (retrieve() can
    # legitimately pull the same-named section from multiple files into its
    # top-K, since it gets a +3.0 score bonus in EVERY file it appears in).
    # Instead, collapse to just the single best-scoring file for this
    # section. `retrieved_chunks` is already sorted by score, so the first
    # chunk matching target_section is our best guess.
    if target_section and not file_filter and allowed_files:
        section_files_in_order = [
            c["file_name"] for c in retrieved_chunks
            if c["section"] == target_section
        ]
        if section_files_in_order:
            allowed_files = {section_files_in_order[0]}
            print(f"  [DEBUG] No file_filter, narrowing '{target_section}' "
                  f"images to top-scoring file → {section_files_in_order[0]}")

    if target_section:
        for key, path in image_map.items():
            parts = key.split("|")
            if len(parts) < 2:
                continue
            if parts[1] != target_section:
                continue
            if file_filter and not _file_matches(parts[0], file_filter):
                continue
            if allowed_files is not None and parts[0] not in allowed_files:
                continue
            if not os.path.exists(path):
                print(f"  [WARN] Image file missing: {path}, skipping")
                continue
            if key not in seen:
                page_part = parts[2] if len(parts) > 2 else "pages1-1"
                page_nums = re.findall(r"\d+", page_part)
                pages = (
                    list(range(int(page_nums[0]), int(page_nums[-1]) + 1))
                    if page_nums else [1]
                )
                images.append({
                    "file_name":  parts[0],
                    "section":    parts[1],
                    "pages":      pages,
                    "image_path": path,
                })
                seen.add(key)

        if not images and chunks is not None:
            print(f"  [INFO] No image found for '{target_section}' — re-extracting …")
            scope = [
                c for c in chunks
                if c["section"] == target_section
                and (file_filter is None or _file_matches(c["file_name"], file_filter))
                and (allowed_files is None or c["file_name"] in allowed_files)
            ]
            if scope:
                new_map = extract_section_images(scope)
                image_map.update(new_map)
                save_image_map(image_map)
                return get_chunk_images(
                    retrieved_chunks, image_map,
                    query=query, file_filter=file_filter, chunks=None
                )

        return images

    for c in retrieved_chunks:
        if c["section"] not in VISUAL_SECTIONS:
            continue
        all_pages = c.get("all_pages") or [c["page"]]
        key = (
            f"{c['file_name']}|{c['section']}|"
            f"pages{all_pages[0]}-{all_pages[-1]}"
        )
        if key in image_map and key not in seen:
            path = image_map[key]
            if os.path.exists(path):
                images.append({
                    "file_name":  c["file_name"],
                    "section":    c["section"],
                    "pages":      all_pages,
                    "image_path": path,
                })
                seen.add(key)

    return images


# ─────────────────────────────────────────────────────────────────────────────
# RETRIEVAL
# ─────────────────────────────────────────────────────────────────────────────
def retrieve(query, model, index, chunks, bm25=None, file_filter=None):
    query_lower = query.lower()

    search_chunks = chunks
    search_index  = index

    if file_filter:
        search_chunks = [
            c for c in chunks
            if c["file_name"].lower() == file_filter.lower()
        ]
        if search_chunks:
            search_index = build_sub_index(model, search_chunks)
        else:
            print(f"[WARN] file_filter '{file_filter}' matched no chunks")
            search_chunks = chunks
            search_index  = index

    visual_section = _detect_visual_section(query)
    if visual_section and file_filter:
        exact = [
            {**c, "score": 999.0}
            for c in search_chunks
            if c["section"] == visual_section
        ]
        if exact:
            return exact[:FINAL_K]

    if file_filter:
        for sec in SECTION_NAMES_LOWER:
            if sec in query_lower:
                exact = [
                    {**c, "score": 999.0}
                    for c in search_chunks
                    if c["section"].lower() == sec
                ]
                if exact:
                    return exact[:FINAL_K]

    is_summary = _is_summary_query(query)
    if is_summary and file_filter:
        summary_chunks = sorted(
            [{**c, "score": 999.0} for c in search_chunks],
            key=lambda x: (x["page"], x["chunk_id"])
        )
        if summary_chunks:
            return summary_chunks[:FINAL_K]

    # Only treat a capitalized token as "the user wants a definition" when
    # the query actually reads like a definition request. Previously ANY
    # capitalized 2-10 letter word (SOP, RACI, OK, a random acronym typed
    # in caps, etc.) triggered this branch and force-scored matching
    # chunks at 1000 -- completely bypassing normal relevance ranking and
    # injecting a possibly-unrelated chunk as if it were certain to be
    # correct. That's a direct hallucination vector: a high forced score
    # tells the LLM "trust this completely" even when it doesn't answer
    # the actual question.
    DEFINE_INTENT_PATTERN = re.compile(
        r"\b(what\s+is|what\s+does|define|definition\s+of|"
        r"full\s+form\s+of|stands?\s+for|meaning\s+of|expand)\b",
        re.IGNORECASE,
    )

    m = re.search(r"\b([A-Z]{2,10})\b", query) if DEFINE_INTENT_PATTERN.search(query) else None

    if m:
        abbr = m.group(1)
        definition_patterns = [
            rf"\b[A-Za-z][A-Za-z0-9\s,&/-]{{3,80}}\(\s*{abbr}\s*\)",
            rf"{abbr}\s*stands\s*for",
            rf"{abbr}\s*:",
            rf"{abbr}\s*-"
        ]
        definition_chunks = []
        for c in search_chunks:
            for p in definition_patterns:
                if re.search(p, c["text"], re.IGNORECASE):
                    cc = c.copy()
                    cc["score"] = 1000.0
                    definition_chunks.append(cc)
                    break
        if definition_chunks:
            definition_chunks.sort(key=lambda x: x["score"], reverse=True)
            return definition_chunks[:1]

    q_emb       = model.encode([query], normalize_embeddings=True)
    scores, ids = search_index.search(np.array(q_emb, dtype="float32"), TOP_K)

    results = []
    for idx, score in zip(ids[0], scores[0]):
        if idx == -1:
            continue
        c          = search_chunks[idx].copy()
        c["score"] = float(score)
        if c["section"].lower() in query_lower:
            c["score"] += 3.0

        if m:
            abbr = m.group(1)
            for p in definition_patterns:
                if re.search(p, c["text"], re.IGNORECASE):
                    c["score"] += 8
                    break

        results.append(c)

    if bm25 and not file_filter:
        bm25_scores = bm25.get_scores(query_lower.split())
        top_bm25    = np.argsort(bm25_scores)[-TOP_K:]
        for i in top_bm25:
            if i >= len(chunks):
                continue
            c          = chunks[i].copy()
            c["score"] = float(bm25_scores[i]) * 0.2
            if m:
                abbr = m.group(1)
                if re.search(rf"\(\s*{abbr}\s*\)", c["text"], re.IGNORECASE):
                    c["score"] += 8
            results.append(c)

    results.sort(key=lambda x: x["score"], reverse=True)

    final    = []
    seen_ids = set()
    for c in results:
        cid = c["chunk_id"]
        if cid not in seen_ids:
            final.append(c)
            seen_ids.add(cid)
        if len(final) >= FINAL_K:
            break

    SCORE_THRESHOLD = 0.25
    filtered = [c for c in final if c["score"] >= SCORE_THRESHOLD]
    if filtered:
        return filtered[:FINAL_K]

    # Previously: return final[:min(FINAL_K, 3)] -- forced through the top 3
    # chunks no matter how irrelevant, and build_prompt() told the LLM it
    # was NEVER allowed to say "not found". That combination guaranteed a
    # confident, fabricated answer any time the real answer wasn't in the
    # corpus. Returning nothing here lets ask() short-circuit to an honest
    # "I couldn't find this" instead of forcing the LLM to invent one.
    return []


# ─────────────────────────────────────────────────────────────────────────────
# GENERAL RETRIEVAL CONFIG
# ─────────────────────────────────────────────────────────────────────────────

GENERAL_TOP_K = 200

GENERAL_FINAL_K = 100

GENERAL_SCORE_THRESHOLD = 0.35

GENERAL_BM25_WEIGHT = 0.60


def retrieve_general(
    query,
    model,
    index,
    chunks,
    bm25=None,
):
    """
    Retrieval pipeline for generalized questions.

    Unlike retrieve(), this function searches ALL SOPs and
    gathers evidence from multiple documents.

    Returns
    -------
    ranked_documents
    """

    print("\n[GENERAL RETRIEVAL MODE]\n")

    # ----------------------------------------------------------
    # FAISS SEARCH
    # ----------------------------------------------------------

    q_emb = model.encode(
        [query],
        normalize_embeddings=True
    )

    scores, ids = index.search(
        np.array(q_emb, dtype="float32"),
        GENERAL_TOP_K,
    )

    faiss_hits = [
        (int(idx), float(score))
        for idx, score in zip(ids[0], scores[0])
        if idx != -1
    ]

    # ----------------------------------------------------------
    # BM25 SEARCH
    # ----------------------------------------------------------

    bm25_hits = []

    if bm25 is not None:

        bm25_scores = bm25.get_scores(
            query.lower().split()
        )

        top = np.argsort(
            bm25_scores
        )[-GENERAL_TOP_K:]

        bm25_hits = [
            (int(i), float(bm25_scores[i]))
            for i in top
        ]

    # ----------------------------------------------------------
    # NORMALIZE EACH SCORE SET TO [0, 1] BEFORE MERGING
    # ----------------------------------------------------------
    # FAISS cosine scores (~-1..1) and raw BM25 scores (often 0..20+)
    # live on completely different scales. Merging them directly with
    # only a flat weight — as before — let BM25 silently dominate the
    # combined ranking, and made GENERAL_SCORE_THRESHOLD meaningless
    # (a strong 0.6 cosine match could never outrank a mediocre BM25
    # hit). Min-max normalising each set independently first puts both
    # signals on the same footing before combining, so the relevance
    # threshold below actually filters on comparable numbers.

    def _minmax_normalise(pairs):
        if not pairs:
            return {}
        vals = [v for _, v in pairs]
        lo, hi = min(vals), max(vals)
        span = hi - lo
        if span < 1e-9:
            return {idx: 1.0 for idx, _ in pairs}
        return {idx: (v - lo) / span for idx, v in pairs}

    faiss_norm = _minmax_normalise(faiss_hits)
    bm25_norm  = _minmax_normalise(bm25_hits)

    results = []

    for idx in set(faiss_norm) | set(bm25_norm):

        chunk = chunks[idx].copy()

        chunk["score"] = (
            faiss_norm.get(idx, 0.0) * (1 - GENERAL_BM25_WEIGHT)
            + bm25_norm.get(idx, 0.0) * GENERAL_BM25_WEIGHT
        )

        results.append(chunk)

    # ----------------------------------------------------------
    # SORT
    # ----------------------------------------------------------

    results.sort(

        key=lambda x: x["score"],

        reverse=True,

    )

    # ----------------------------------------------------------
    # KEEP ONLY RELEVANT CHUNKS
    # ----------------------------------------------------------
    # NOTE: this block used to be commented out while the code below it
    # still referenced `relevant_chunks` — a guaranteed NameError on
    # every single general-question query (is_general_question() routes
    # here for anything like "what is X" / "responsibilities of Y").
    # Restored, and now operating on properly normalised scores.

    relevant_chunks = [
        c
        for c in results
        if c["score"] >= GENERAL_SCORE_THRESHOLD
    ]

    # ----------------------------------------------------------
    # If nothing survives,
    # return best few anyway.
    # ----------------------------------------------------------

    if not relevant_chunks:

        relevant_chunks = results[:15]

    # ----------------------------------------------------------
    # GROUP BY DOCUMENT
    # ----------------------------------------------------------

    grouped = group_chunks_by_document(
        relevant_chunks
    )

    ranked_documents = rank_documents(
        grouped
    )

    print_matching_documents(
        ranked_documents
    )

    return ranked_documents


def flatten_ranked_documents(
    ranked_documents,
    max_chunks_per_document=8,
):
    """
    Convert ranked documents back into a list
    of chunks for the LLM.

    Keeps only the best chunks from each PDF.
    """

    final_chunks = []

    for doc in ranked_documents:

        chunks = sorted(

            doc["chunks"],

            key=lambda x: x["score"],

            reverse=True,

        )

        final_chunks.extend(

            chunks[:max_chunks_per_document]

        )

    return final_chunks

# ─────────────────────────────────────────────────────────────────────────────
# GENERAL CONTEXT BUILDING
# ─────────────────────────────────────────────────────────────────────────────

def build_general_context(
    ranked_documents,
    max_chunks_per_document=6,
):
    """
    Builds a structured context for the LLM.

    Instead of mixing chunks from different PDFs together,
    chunks are grouped by their source document.

    Returns one large string.
    """

    context_parts = []

    for doc in ranked_documents:

        context_parts.append("\n" + "=" * 70)
        context_parts.append(f"DOCUMENT : {doc['file_name']}")
        context_parts.append(
            f"Matching Sections : {doc['matches']}"
        )
        context_parts.append("=" * 70)

        chunks = sorted(
            doc["chunks"],
            key=lambda x: x["score"],
            reverse=True,
        )

        for chunk in chunks[:max_chunks_per_document]:

            context_parts.append(

                f"""
Section : {chunk['section']}
Page    : {chunk['page']}
Score   : {chunk['score']:.3f}

{chunk['text']}
"""
            )

    return "\n".join(context_parts)


def build_general_prompt(
    query,
    ranked_documents,
):
    """
    Prompt used ONLY for generalized questions.
    """

    context = build_general_context(
        ranked_documents
    )

    return f"""
You are an enterprise SOP assistant.

The retrieved context comes from MULTIPLE SOP documents.

Your task is to answer the user's question by comparing all relevant SOPs.

Rules

1. Use ONLY the supplied context.

2. Never use outside knowledge.

3. If multiple SOPs define the same concept,
   merge them into one coherent answer.

4. If different SOPs describe different responsibilities,
   include all of them.

5. If documents disagree,
   explicitly mention the difference.

6. If only one SOP mentions something,
   clearly say that.

7. At the end include a section called

Supporting SOPs

listing every SOP that contributed.

8. Never invent information.

9. If the answer cannot be found,
   say so.

------------------------------------------------------------

CONTEXT

{context}

------------------------------------------------------------

QUESTION

{query}

------------------------------------------------------------

ANSWER
"""


def build_source_summary(
    ranked_documents,
):
    """
    Returns a clean summary of which SOPs
    contributed to the answer.
    """

    summary = []

    for doc in ranked_documents:

        summary.append(

            {

                "file_name": doc["file_name"],

                "matches": doc["matches"],

                "avg_score": round(
                    doc["avg_score"],
                    3,
                ),

            }

        )

    return summary


def balance_documents(
    ranked_documents,
    max_chunks=6,
):
    """
    Limits the number of chunks taken
    from any one document.

    Prevents a single large SOP
    from overwhelming smaller ones.
    """

    balanced = []

    for doc in ranked_documents:

        chunks = sorted(

            doc["chunks"],

            key=lambda x: x["score"],

            reverse=True,

        )

        new_doc = doc.copy()

        new_doc["chunks"] = chunks[:max_chunks]

        balanced.append(new_doc)

    return balanced

# ─────────────────────────────────────────────────────────────────────────────
# PROMPT BUILDING
# ─────────────────────────────────────────────────────────────────────────────
def build_prompt(query, chunks, file_filter=None):
    context = "\n\n".join(
        f"[{c['file_name']} | Page {c.get('page')} | Section: {c.get('section')}]\n{c['text']}"
        for c in chunks
    )
    file_rule = f"\nONLY use information from '{file_filter}'." if file_filter else ""

    is_summary = _is_summary_query(query)
    summary_rule = (
        "\n12. The user wants a SUMMARY. Synthesise ALL provided chunks into a "
        "coherent overview — cover purpose, scope, key processes, responsibilities, "
        "and any important references. Do NOT say information is missing; use what is given."
    ) if is_summary else ""

    return f"""You are a strict SOP assistant.

Rules:
1. Use ONLY the supplied context — never fabricate information, and never
   fall back on outside/general knowledge to fill gaps.
2. If the answer exists in the context, provide it in full, staying close
   to the source's own wording for key facts (names, numbers, roles,
   thresholds, steps).
3. When multiple chunks are provided, prioritise exact section matches.
4. Always cite the file name, page number, and section for every fact.
5. Quote the relevant text where useful.{file_rule}
6. Answer ONLY using the chunks that directly answer the user's question.
   Ignore any chunk that is merely topically related but doesn't actually
   address what was asked.
7. If NONE of the supplied chunks actually answer the question, say so
   plainly — e.g. "The provided SOP context does not cover this." Do not
   guess, extrapolate, or answer from a chunk that doesn't really address
   the question just to avoid saying it wasn't found.
8. If exactly one chunk answers the question, answer only from that chunk.
9. If multiple chunks cover the same topic, you may merge them into one
   coherent answer, but do NOT combine facts from different chunks into a
   new claim that neither chunk states on its own.
10. Always cite only the chunk(s) actually used for the answer.{summary_rule}

CONTEXT:
{context}

QUESTION:
{query}

ANSWER:"""


# ─────────────────────────────────────────────────────────────────────────────
# LLM CALL
# ─────────────────────────────────────────────────────────────────────────────
def generate(prompt):
    client = Groq(api_key=GROQ_API_KEY)
    res = client.chat.completions.create(
        model=LLM_MODEL,
        messages=[
            {"role": "system", "content": "You are a strict SOP assistant. Never hallucinate."},
            {"role": "user",   "content": prompt},
        ],
        temperature=0.1,
        max_tokens=1500,
    )
    return res.choices[0].message.content


# ─────────────────────────────────────────────────────────────────────────────
# ADD NEW DOCUMENTS
# ─────────────────────────────────────────────────────────────────────────────
def add_new_documents(model, chunks, index):
    global LAST_UPLOADED_FILE

    processed = load_processed()
    new_files = get_new_pdfs()

    if not new_files:
        print("No new PDFs found")
        return chunks, index

    print(f"Found {len(new_files)} new PDF(s)")

    layout_cache_json = load_layout_cache_json()

    docs = []
    for pdf in new_files:
        try:
            pdf_doc = fitz.open(str(pdf))
            cleaner = get_layout_cleaner(pdf_doc, pdf.name, layout_cache_json)
            pages   = []
            for i in range(len(pdf_doc)):
                # same clean-text extraction as load_pdfs() — see that function
                # for what get_clean_text() strips and why
                text = cleaner.get_clean_text(pdf_doc[i]).strip()
                pages.append({"page": i + 1, "text": text})   # same fix as load_pdfs()
            pdf_doc.close()
            docs.append({"file_name": pdf.name, "pages": pages})
        except Exception as e:
            print(f"\n  [ERROR] Failed to load/analyze new PDF '{pdf.name}': {e}")
            traceback.print_exc()
            print(f"  [SKIP] Continuing with remaining new PDFs...\n")
            continue

    save_layout_cache_json(layout_cache_json)

    new_chunks = chunk_documents(docs)
    if not new_chunks:
        return chunks, index

    next_id = max([c["chunk_id"] for c in chunks], default=-1) + 1
    for i, c in enumerate(new_chunks):
        c["chunk_id"] = next_id + i

    texts      = [_chunk_to_text(c) for c in new_chunks]
    embeddings = model.encode(texts, normalize_embeddings=True, batch_size=32, show_progress_bar=True)
    index.add(np.array(embeddings, dtype="float32"))

    chunks.extend(new_chunks)

    new_image_map = extract_section_images(new_chunks)
    image_map     = load_image_map()
    image_map.update(new_image_map)

    save_image_map(image_map)
    save_chunks(chunks)
    faiss.write_index(index, INDEX_FILE)

    for pdf in new_files:
        processed[pdf.name] = file_hash(pdf)
    save_processed(processed)

    LAST_UPLOADED_FILE = new_files[-1].name
    _save_last_uploaded(LAST_UPLOADED_FILE)   # persist across restarts

    print(f"Added {len(new_chunks)} new chunks")
    print(f"[LAST_UPLOADED_FILE] → {LAST_UPLOADED_FILE}")
    return chunks, index


