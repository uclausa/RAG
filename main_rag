from collections import defaultdict


def group_chunks_by_document(retrieved_chunks):
    """
    Groups retrieved chunks by PDF.

    Returns

    {
        file1.pdf : [chunk1, chunk2, ...],
        file2.pdf : [chunk3, chunk4, ...]
    }
    """

    grouped = defaultdict(list)

    for chunk in retrieved_chunks:

        grouped[chunk["file_name"]].append(chunk)

    return grouped


def rank_documents(grouped_chunks):
    """
    Rank documents instead of chunks.

    Score =
        Average relevance
      + Number of matching chunks
      + Best chunk score
    """

    ranked = []

    for file_name, docs in grouped_chunks.items():

        scores = [c["score"] for c in docs]

        avg_score = np.mean(scores)

        best_score = max(scores)

        match_count = len(docs)

        document_score = (

            avg_score * 0.50 +

            best_score * 0.30 +

            min(match_count / 10, 1.0) * 0.20

        )

        ranked.append({

            "file_name": file_name,

            "chunks": docs,

            "matches": match_count,

            "avg_score": avg_score,

            "best_score": best_score,

            "document_score": document_score,

        })

    ranked.sort(

        key=lambda x: x["document_score"],

        reverse=True,

    )

    return ranked



def select_chunks_per_document(

    ranked_documents,

    max_chunks=5,

):

    """
    Keep the best chunks from EVERY document.

    No document can dominate retrieval.
    """

    selected = []

    for doc in ranked_documents:

        ordered = sorted(

            doc["chunks"],

            key=lambda x: x["score"],

            reverse=True,

        )

        selected.extend(

            ordered[:max_chunks]

        )

    return selected




